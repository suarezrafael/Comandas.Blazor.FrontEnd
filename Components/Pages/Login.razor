@page "/login"
@using Comandas.Blazor.FrontEnd.Services
@inject AutenticacaoService AutenticacaoService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Login</PageTitle>

<div class="container">
    <div class="row justify-content-center mt-5">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow">
                <div class="card-body">
                    <h3 class="card-title text-center mb-4">Login</h3>
                    
                    @if (!string.IsNullOrEmpty(_mensagemErro))
                    {
                        <div class="alert alert-danger" role="alert">
                            @_mensagemErro
                        </div>
                    }

                    <EditForm Model="@_loginModel" OnValidSubmit="@HandleLogin">
                        <DataAnnotationsValidator />
                        
                        <div class="mb-3">
                            <label for="email" class="form-label">Email</label>
                            <InputText id="email" class="form-control" @bind-Value="_loginModel.Email" placeholder="seu@email.com" />
                            <ValidationMessage For="@(() => _loginModel.Email)" />
                        </div>

                        <div class="mb-3">
                            <label for="senha" class="form-label">Senha</label>
                            <InputText id="senha" type="password" class="form-control" @bind-Value="_loginModel.Senha" placeholder="Digite sua senha" />
                            <ValidationMessage For="@(() => _loginModel.Senha)" />
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary" disabled="@_processando">
                                @if (_processando)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                }
                                Entrar
                            </button>
                        </div>
                    </EditForm>

                    <div class="text-center mt-3">
                        <p class="text-muted">Não tem uma conta? <a href="/usuarios/cadastro">Cadastre-se</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private LoginModel _loginModel = new();
    private bool _processando = false;
    private string _mensagemErro = string.Empty;

    protected override void OnInitialized()
    {
        if (AutenticacaoService.EstaAutenticado)
        {
            NavigationManager.NavigateTo("/");
        }
    }

    private async Task HandleLogin()
    {
        _processando = true;
        _mensagemErro = string.Empty;
        StateHasChanged();

        try
        {
            var sucesso = await AutenticacaoService.Login(_loginModel.Email, _loginModel.Senha);
            
            if (sucesso)
            {
                NavigationManager.NavigateTo("/");
            }
            else
            {
                _mensagemErro = "Email ou senha inválidos.";
            }
        }
        catch (Exception ex)
        {
            _mensagemErro = $"Erro ao fazer login: {ex.Message}";
        }
        finally
        {
            _processando = false;
            StateHasChanged();
        }
    }

    public class LoginModel
    {
        [Required(ErrorMessage = "Email é obrigatório")]
        [EmailAddress(ErrorMessage = "Email inválido")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Senha é obrigatória")]
        [MinLength(6, ErrorMessage = "A senha deve ter no mínimo 6 caracteres")]
        public string Senha { get; set; } = string.Empty;
    }
}
