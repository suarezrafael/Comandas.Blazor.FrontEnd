@page "/menu"
@using ComandasBlazor.Services
@inject AuthService AuthService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Menu Principal</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="page-header">🍽️ Menu Principal</h1>
        <div>
            <span class="me-3">Bem-vindo, <strong>@AuthService.CurrentUser?.Nome</strong></span>
            <button class="btn btn-danger btn-sm" @onclick="Logout">Sair</button>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card card-restaurant h-100">
                <div class="card-header">
                    📋 Cardápio
                </div>
                <div class="card-body">
                    <p class="card-text">Gerencie os itens do cardápio do restaurante.</p>
                    <a href="/cardapio" class="btn btn-primary">Acessar</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card card-restaurant h-100">
                <div class="card-header">
                    🪑 Mesas
                </div>
                <div class="card-body">
                    <p class="card-text">Gerencie as mesas do restaurante.</p>
                    <a href="/mesas" class="btn btn-primary">Acessar</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card card-restaurant h-100">
                <div class="card-header">
                    👥 Usuários
                </div>
                <div class="card-body">
                    <p class="card-text">Gerencie os usuários do sistema.</p>
                    <a href="/usuarios" class="btn btn-primary">Acessar</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card card-restaurant h-100">
                <div class="card-header">
                    📝 Comandas
                </div>
                <div class="card-body">
                    <p class="card-text">Abra e gerencie as comandas dos clientes.</p>
                    <a href="/comandas" class="btn btn-primary">Acessar</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card card-restaurant h-100">
                <div class="card-header">
                    🍳 Pedidos da Cozinha
                </div>
                <div class="card-body">
                    <p class="card-text">Gerencie os pedidos da cozinha.</p>
                    <a href="/pedidos" class="btn btn-primary">Acessar</a>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/", true);
        }
    }

    private void Logout()
    {
        AuthService.Logout();
        Navigation.NavigateTo("/", true);
    }
}
