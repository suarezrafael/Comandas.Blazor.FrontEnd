@page "/comandas/novo"
@page "/comandas/editar/{Id:int}"
@using ComandasBlazor.Models
@using ComandasBlazor.Services
@inject ApiService ApiService
@inject AuthService AuthService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>@(Id.HasValue ? "Editar Comanda" : "Nova Comanda")</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="page-header">@(Id.HasValue ? "✏️ Editar Comanda" : "➕ Nova Comanda")</h1>
        <a href="/comandas" class="btn btn-secondary">← Voltar</a>
    </div>

    <div class="card card-restaurant">
        <div class="card-body">
            @if (Id.HasValue)
            {
                <EditForm Model="@comandaUpdate" OnValidSubmit="HandleUpdate">
                    <div class="mb-3">
                        <label for="numeroMesa" class="form-label">Número da Mesa</label>
                        <InputNumber id="numeroMesa" class="form-control" @bind-Value="comandaUpdate.NumeroMesa" />
                    </div>

                    <div class="mb-3">
                        <label for="nomeCliente" class="form-label">Nome do Cliente</label>
                        <InputText id="nomeCliente" class="form-control" @bind-Value="comandaUpdate.NomeCliente" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Itens da Comanda</label>
                        @if (cardapioItems != null)
                        {
                            <div class="row">
                                @foreach (var item in cardapioItems)
                                {
                                    var existingItem = comandaUpdate.ComandaItens?.FirstOrDefault(ci => ci.CardapioItemId == item.Id);
                                    var isChecked = existingItem != null;

                                    <div class="col-md-6 mb-2">
                                        <div class="form-check">
                                            <input type="checkbox" class="form-check-input" 
                                                   id="item_@item.Id" 
                                                   checked="@isChecked"
                                                   @onchange="@(e => ToggleItem(item.Id, (bool)e.Value!))" />
                                            <label class="form-check-label" for="item_@item.Id">
                                                @item.Titulo - R$ @item.Preco.ToString("F2")
                                            </label>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger" role="alert">
                            @errorMessage
                        </div>
                    }

                    <button type="submit" class="btn btn-primary" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>Salvando...</span>
                        }
                        else
                        {
                            <span>💾 Salvar</span>
                        }
                    </button>
                </EditForm>
            }
            else
            {
                <EditForm Model="@comandaDto" OnValidSubmit="HandleCreate">
                    <div class="mb-3">
                        <label for="numeroMesa" class="form-label">Número da Mesa</label>
                        <InputNumber id="numeroMesa" class="form-control" @bind-Value="comandaDto.NumeroMesa" />
                    </div>

                    <div class="mb-3">
                        <label for="nomeCliente" class="form-label">Nome do Cliente</label>
                        <InputText id="nomeCliente" class="form-control" @bind-Value="comandaDto.NomeCliente" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Itens do Cardápio</label>
                        @if (cardapioItems != null)
                        {
                            <div class="row">
                                @foreach (var item in cardapioItems)
                                {
                                    <div class="col-md-6 mb-2">
                                        <div class="form-check">
                                            <input type="checkbox" class="form-check-input" 
                                                   id="item_@item.Id" 
                                                   value="@item.Id"
                                                   @onchange="@(e => ToggleItemCreate(item.Id, (bool)e.Value!))" />
                                            <label class="form-check-label" for="item_@item.Id">
                                                @item.Titulo - R$ @item.Preco.ToString("F2")
                                            </label>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger" role="alert">
                            @errorMessage
                        </div>
                    }

                    <button type="submit" class="btn btn-primary" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>Salvando...</span>
                        }
                        else
                        {
                            <span>💾 Salvar</span>
                        }
                    </button>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int? Id { get; set; }

    private ComandaDto comandaDto = new() { CardapioItems = new List<int>() };
    private ComandaUpdateDto comandaUpdate = new() { ComandaItens = new List<ComandaItemUpdateDto>() };
    private List<CardapioItem>? cardapioItems;
    private string errorMessage = string.Empty;
    private bool isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/", true);
            return;
        }

        cardapioItems = await ApiService.GetAsync<List<CardapioItem>>("api/CardapioItems");

        if (Id.HasValue)
        {
            var existingComanda = await ApiService.GetAsync<ComandaGetDto>($"api/Comandas/{Id.Value}");
            if (existingComanda != null)
            {
                comandaUpdate.Id = existingComanda.Id;
                comandaUpdate.NumeroMesa = existingComanda.NumeroMesa;
                comandaUpdate.NomeCliente = existingComanda.NomeCliente;
                comandaUpdate.ComandaItens = existingComanda.ComandaItens?
                    .Select(i => new ComandaItemUpdateDto { Id = i.Id, CardapioItemId = 0 })
                    .ToList() ?? new List<ComandaItemUpdateDto>();
            }
        }
    }

    private void ToggleItemCreate(int itemId, bool isChecked)
    {
        comandaDto.CardapioItems ??= new List<int>();
        
        if (isChecked && !comandaDto.CardapioItems.Contains(itemId))
        {
            comandaDto.CardapioItems.Add(itemId);
        }
        else if (!isChecked && comandaDto.CardapioItems.Contains(itemId))
        {
            comandaDto.CardapioItems.Remove(itemId);
        }
    }

    private void ToggleItem(int itemId, bool isChecked)
    {
        comandaUpdate.ComandaItens ??= new List<ComandaItemUpdateDto>();
        
        var existingItem = comandaUpdate.ComandaItens.FirstOrDefault(ci => ci.CardapioItemId == itemId);
        
        if (isChecked && existingItem == null)
        {
            comandaUpdate.ComandaItens.Add(new ComandaItemUpdateDto
            {
                CardapioItemId = itemId,
                Incluir = true
            });
        }
        else if (!isChecked && existingItem != null)
        {
            existingItem.Excluir = true;
        }
    }

    private async Task HandleCreate()
    {
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            var result = await ApiService.PostAsync<Comanda>("api/Comandas", comandaDto);
            if (result != null)
            {
                Navigation.NavigateTo("/comandas");
            }
            else
            {
                errorMessage = "Erro ao criar comanda.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleUpdate()
    {
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            var success = await ApiService.PutAsync($"api/Comandas/{Id!.Value}", comandaUpdate);
            if (success)
            {
                Navigation.NavigateTo("/comandas");
            }
            else
            {
                errorMessage = "Erro ao atualizar comanda.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}
