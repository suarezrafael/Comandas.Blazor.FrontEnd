@page "/pedidos"
@using ComandasBlazor.Models
@using ComandasBlazor.Services
@inject ApiService ApiService
@inject AuthService AuthService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Pedidos da Cozinha</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="page-header">🍳 Pedidos da Cozinha</h1>
        <div>
            <button class="btn btn-primary me-2" @onclick="LoadPedidos">🔄 Atualizar</button>
            <a href="/menu" class="btn btn-secondary">🏠 Menu</a>
        </div>
    </div>

    <div class="mb-3">
        <label for="situacaoFilter" class="form-label">Filtrar por Situação:</label>
        <select id="situacaoFilter" class="form-select" @bind="situacaoFiltro" @bind:after="LoadPedidos">
            <option value="">Todos</option>
            <option value="1">Em Preparo</option>
            <option value="2">Pronto</option>
            <option value="3">Entregue</option>
        </select>
    </div>

    @if (isLoading)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Carregando...</span>
            </div>
        </div>
    }
    else if (pedidos == null || !pedidos.Any())
    {
        <div class="alert alert-info">
            Nenhum pedido encontrado.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-restaurant table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Mesa</th>
                        <th>Cliente</th>
                        <th>Item</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pedido in pedidos)
                    {
                        <tr>
                            <td>@pedido.Id</td>
                            <td>Mesa @pedido.NumeroMesa</td>
                            <td>@pedido.NomeCliente</td>
                            <td>@pedido.Titulo</td>
                            <td>
                                <button class="btn btn-sm btn-warning me-1" @onclick="() => UpdateStatus(pedido.Id, 1)" title="Em Preparo">
                                    🔄 Preparo
                                </button>
                                <button class="btn btn-sm btn-success me-1" @onclick="() => UpdateStatus(pedido.Id, 2)" title="Pronto">
                                    ✅ Pronto
                                </button>
                                <button class="btn btn-sm btn-primary" @onclick="() => UpdateStatus(pedido.Id, 3)" title="Entregue">
                                    🚚 Entregue
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<PedidoCozinhaGetDto>? pedidos;
    private bool isLoading = true;
    private string situacaoFiltro = "";

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/", true);
            return;
        }

        await LoadPedidos();
    }

    private async Task LoadPedidos()
    {
        isLoading = true;
        var endpoint = "api/PedidoCozinhas";
        
        if (!string.IsNullOrEmpty(situacaoFiltro))
        {
            endpoint += $"?situacaoId={situacaoFiltro}";
        }
        
        pedidos = await ApiService.GetAsync<List<PedidoCozinhaGetDto>>(endpoint);
        isLoading = false;
    }

    private async Task UpdateStatus(int id, int novoStatus)
    {
        var updateDto = new PedidoCozinhaUpdateDto { NovoStatusId = novoStatus };
        var success = await ApiService.PutAsync($"api/PedidoCozinhas/{id}", updateDto);
        
        if (success)
        {
            await LoadPedidos();
        }
    }
}
