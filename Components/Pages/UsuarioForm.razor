@page "/usuarios/cadastro"
@page "/usuarios/editar/{Id:int}"
@using Comandas.Blazor.FrontEnd.Models
@using Comandas.Blazor.FrontEnd.Services
@inject UsuarioService UsuarioService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>@(_ehEdicao ? "Editar Usuário" : "Cadastrar Usuário")</PageTitle>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header">
                    <h4>@(_ehEdicao ? "Editar Usuário" : "Cadastrar Novo Usuário")</h4>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(_mensagemErro))
                    {
                        <div class="alert alert-danger" role="alert">
                            @_mensagemErro
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(_mensagemSucesso))
                    {
                        <div class="alert alert-success" role="alert">
                            @_mensagemSucesso
                        </div>
                    }

                    @if (_carregando)
                    {
                        <div class="text-center">
                            <div class="spinner-border" role="status">
                                <span class="visually-hidden">Carregando...</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <EditForm Model="@_usuario" OnValidSubmit="@HandleSubmit">
                            <DataAnnotationsValidator />
                            
                            <div class="mb-3">
                                <label for="nome" class="form-label">Nome Completo</label>
                                <InputText id="nome" class="form-control" @bind-Value="_usuario.Nome" placeholder="Digite o nome completo" />
                                <ValidationMessage For="@(() => _usuario.Nome)" />
                            </div>

                            <div class="mb-3">
                                <label for="email" class="form-label">Email</label>
                                <InputText id="email" class="form-control" @bind-Value="_usuario.Email" placeholder="email@exemplo.com" />
                                <ValidationMessage For="@(() => _usuario.Email)" />
                            </div>

                            <div class="mb-3">
                                <label for="senha" class="form-label">
                                    @(_ehEdicao ? "Senha (deixe em branco para manter a atual)" : "Senha")
                                </label>
                                <InputText id="senha" type="password" class="form-control" @bind-Value="_usuario.Senha" placeholder="Digite a senha" />
                                @if (!_ehEdicao)
                                {
                                    <ValidationMessage For="@(() => _usuario.Senha)" />
                                }
                            </div>

                            @if (_ehEdicao)
                            {
                                <div class="mb-3 form-check">
                                    <InputCheckbox id="ativo" class="form-check-input" @bind-Value="_usuario.Ativo" />
                                    <label class="form-check-label" for="ativo">
                                        Usuário Ativo
                                    </label>
                                </div>
                            }

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary" disabled="@_processando">
                                    @if (_processando)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    }
                                    @(_ehEdicao ? "Atualizar" : "Cadastrar")
                                </button>
                                <button type="button" class="btn btn-secondary" @onclick="Voltar">
                                    Cancelar
                                </button>
                            </div>
                        </EditForm>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int? Id { get; set; }

    private UsuarioModel _usuario = new();
    private bool _ehEdicao => Id.HasValue && Id.Value > 0;
    private bool _carregando = false;
    private bool _processando = false;
    private string _mensagemErro = string.Empty;
    private string _mensagemSucesso = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (_ehEdicao)
        {
            _carregando = true;
            var usuario = await UsuarioService.ObterPorId(Id!.Value);
            
            if (usuario != null)
            {
                _usuario.Id = usuario.Id;
                _usuario.Nome = usuario.Nome;
                _usuario.Email = usuario.Email;
                _usuario.Ativo = usuario.Ativo;
            }
            else
            {
                _mensagemErro = "Usuário não encontrado.";
            }
            
            _carregando = false;
        }
    }

    private async Task HandleSubmit()
    {
        _processando = true;
        _mensagemErro = string.Empty;
        _mensagemSucesso = string.Empty;
        StateHasChanged();

        try
        {
            var usuario = new Usuario
            {
                Id = _usuario.Id,
                Nome = _usuario.Nome,
                Email = _usuario.Email,
                Senha = _usuario.Senha,
                Ativo = _usuario.Ativo
            };

            bool sucesso;
            
            if (_ehEdicao)
            {
                sucesso = await UsuarioService.Atualizar(usuario);
                if (sucesso)
                {
                    _mensagemSucesso = "Usuário atualizado com sucesso!";
                    await Task.Delay(1500);
                    NavigationManager.NavigateTo("/usuarios");
                }
                else
                {
                    _mensagemErro = "Erro ao atualizar usuário. Verifique se o email já está em uso.";
                }
            }
            else
            {
                sucesso = await UsuarioService.Criar(usuario);
                if (sucesso)
                {
                    _mensagemSucesso = "Usuário cadastrado com sucesso!";
                    await Task.Delay(1500);
                    NavigationManager.NavigateTo("/usuarios");
                }
                else
                {
                    _mensagemErro = "Erro ao cadastrar usuário. O email já está em uso.";
                }
            }
        }
        catch (Exception ex)
        {
            _mensagemErro = $"Erro: {ex.Message}";
        }
        finally
        {
            _processando = false;
            StateHasChanged();
        }
    }

    private void Voltar()
    {
        NavigationManager.NavigateTo("/usuarios");
    }

    public class UsuarioModel
    {
        public int Id { get; set; }

        [Required(ErrorMessage = "Nome é obrigatório")]
        [StringLength(100, ErrorMessage = "Nome deve ter no máximo 100 caracteres")]
        public string Nome { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email é obrigatório")]
        [EmailAddress(ErrorMessage = "Email inválido")]
        public string Email { get; set; } = string.Empty;

        [StringLength(50, MinimumLength = 6, ErrorMessage = "A senha deve ter entre 6 e 50 caracteres")]
        public string Senha { get; set; } = string.Empty;

        public bool Ativo { get; set; } = true;
    }
}
